ai config add --name Claude --type claude --model "claude-opus-4-6" --secret-key '${secret:PERSONAL_CLAUDE_API_KEY}' --url "https://api.anthropic.com/v1/"
ai prompt --text "Say hello like a pirate"  --endpoint claude
