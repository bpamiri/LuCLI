# Multi-agent pending-code review workflow
# Usage:
#   lucli pr-review/review-pending-code.lucli
#
# Expected input file:
#   pr-review/out/pr_context.json
#
# Endpoint names should match your configured LuCLI AI endpoints.

set PR_CONTEXT_FILE=pr-review/out/pr_context.json
set REVIEW_PROMPT_FILE=pr-review/prompts/reviewer-system.md
set SYNTH_PROMPT_FILE=pr-review/prompts/synthesis-system.md
set RULES_FOLDER=pr-review/rules

set CLAUDE_ENDPOINT=Claude
set GEMINI_ENDPOINT=Gemini
set CODEX_ENDPOINT=Codex
set SYNTHESIS_ENDPOINT=OpenAI

set CLAUDE_REPORT=pr-review/out/reviews/claude.md
set GEMINI_REPORT=pr-review/out/reviews/gemini.md
set CODEX_REPORT=pr-review/out/reviews/codex.md
set SYNTHESIS_INPUT=pr-review/out/synthesis_input.md
set FINAL_REPORT=pr-review/out/review_summary.md

echo "Running pending-code review from: ${PR_CONTEXT_FILE}"

echo "Reviewer 1/3: ${CLAUDE_ENDPOINT}"
ai prompt --endpoint ${CLAUDE_ENDPOINT} --system @${REVIEW_PROMPT_FILE} --rules-folder ${RULES_FOLDER} --text @${PR_CONTEXT_FILE} --output-file ${CLAUDE_REPORT} --force

echo "Reviewer 2/3: ${GEMINI_ENDPOINT}"
ai prompt --endpoint ${GEMINI_ENDPOINT} --system @${REVIEW_PROMPT_FILE} --rules-folder ${RULES_FOLDER} --text @${PR_CONTEXT_FILE} --output-file ${GEMINI_REPORT} --force

echo "Reviewer 3/3: ${CODEX_ENDPOINT}"
ai prompt --endpoint ${CODEX_ENDPOINT} --system @${REVIEW_PROMPT_FILE} --rules-folder ${RULES_FOLDER} --text @${PR_CONTEXT_FILE} --output-file ${CODEX_REPORT} --force

echo "# Pending Code Context" > ${SYNTHESIS_INPUT}
cat ${PR_CONTEXT_FILE} >> ${SYNTHESIS_INPUT}

echo "" >> ${SYNTHESIS_INPUT}
# echo "# Reviewer Output: Claude" >> ${SYNTHESIS_INPUT}
# cat ${CLAUDE_REPORT} >> ${SYNTHESIS_INPUT}

echo "" >> ${SYNTHESIS_INPUT}~
echo "# Reviewer Output: Gemini" >> ${SYNTHESIS_INPUT}
cat ${GEMINI_REPORT} >> ${SYNTHESIS_INPUT}

echo "" >> ${SYNTHESIS_INPUT}
echo "# Reviewer Output: Codex" >> ${SYNTHESIS_INPUT}
cat ${CODEX_REPORT} >> ${SYNTHESIS_INPUT}

echo "Synthesizing final report with: ${SYNTHESIS_ENDPOINT}"
ai prompt --endpoint ${SYNTHESIS_ENDPOINT} --system @${SYNTH_PROMPT_FILE} --rules-folder ${RULES_FOLDER} --text @${SYNTHESIS_INPUT} --output-file ${FINAL_REPORT} --force

echo "Done."
echo "Individual reports:"
# echo "  - ${CLAUDE_REPORT}"
echo "  - ${GEMINI_REPORT}"
echo "  - ${CODEX_REPORT}"
echo "Final summary:"
echo "  - ${FINAL_REPORT}"
