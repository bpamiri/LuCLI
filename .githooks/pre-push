#!/bin/bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

# Prefer project-pinned SDKs from .sdkmanrc without invoking sdk shell functions.
if [[ -f "$ROOT_DIR/.sdkmanrc" ]]; then
  SDKMAN_JAVA_VERSION="$(grep '^java=' "$ROOT_DIR/.sdkmanrc" | head -n 1 | cut -d'=' -f2- | xargs || true)"
  if [[ -n "$SDKMAN_JAVA_VERSION" && -d "$HOME/.sdkman/candidates/java/$SDKMAN_JAVA_VERSION" ]]; then
    export JAVA_HOME="$HOME/.sdkman/candidates/java/$SDKMAN_JAVA_VERSION"
    export PATH="$JAVA_HOME/bin:$PATH"
  fi
fi

echo "Running pre-push checks..."
echo "1/2: mvn clean test"
mvn clean test
echo "2/2: ./tests/test-bats.sh"
./tests/test-bats.sh

echo "Pre-push checks passed."
